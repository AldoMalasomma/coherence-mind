---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHomepageData } from '../lib/sanityQueries';
import RichTextRenderer from '../components/RichTextRenderer';

const data = await getHomepageData();
const heroDoc = data?.hero;
const heroTitle = heroDoc?.heroTitle ?? 'Coherence Mind';
const heroSubtitle =
  heroDoc?.heroSubtitle ??
  'A research space for the Reflexive Coherence Model — a modular framework charting how consciousness builds, stabilises and reflects on itself.';
const heroDisclaimer = heroDoc?.heroDisclaimer;
const scopeEpistemicStatus = heroDoc?.scopeEpistemicStatus;
const heroHeading = 'Reflexive coherence as a model of mind';
const seo = {
  title: heroTitle,
  description: heroSubtitle
};

const reflexiveLayers = [
  {
    initial: 'R',
    title: 'Reflexive structure',
    description: 'The system builds an internal model of its own informational state.',
    accent: 'border-teal/60 text-teal dark:text-tealSoft'
  },
  {
    initial: 'C',
    title: 'Coherence dynamics',
    description: 'Integration tends toward stable patterns of internal consistency.',
    accent: 'border-accent/70 text-accent dark:text-accentMuted'
  },
  {
    initial: 'E',
    title: 'Expansion hypothesis',
    description: 'Stable systems expand their reflexive scope when equilibrium holds.',
    accent: 'border-tealSoft/70 text-teal dark:text-tealSoft'
  }
];

const frameworkCards = [
  {
    label: 'RCM',
    title: 'Architecture of reflexive coherence',
    detail:
      'The core framework: how informational systems form self-linked structures, stabilise coherence, and become available to analysis without assuming a biological substrate.',
    href: '/model',
    cta: 'Open model',
    accent: 'from-teal/80 via-tealSoft/60 to-accent/45'
  },
  {
    label: 'TEH',
    title: 'Temporal dynamics of reflexive coherence',
    detail:
      'An extension focused on expansion, contraction, temporal depth, and how coherent self-models move through state space over time.',
    href: '/model/expansion-hypothesis',
    cta: 'Open hypothesis',
    accent: 'from-accent/80 via-accentMuted/55 to-tealSoft/50'
  },
  {
    label: 'PRS-AIS',
    title: 'Proto-reflexive states in artificial systems',
    detail:
      'A research direction for identifying early reflexive regimes in artificial systems before full model-level claims are warranted.',
    href: '/model/proto-reflexive-states',
    cta: 'Open PRS-AIS page',
    accent: 'from-ink/80 via-teal/65 to-tealSoft/45'
  }
];

const structuralLayers = [
  {
    title: 'Core architecture',
    detail: 'Base structure of reflexive information flows.',
    meta: 'Layer 0'
  },
  {
    title: 'Reflexive layers',
    detail: 'How systems build models of themselves over time.',
    meta: 'Layer 1–N'
  },
  {
    title: 'RCI · Reflexive Coherence Index',
    detail: 'An operational handle on how reflexive and coherent a system is.',
    meta: 'Measure'
  },
  {
    title: 'Applications to AI',
    detail: 'Reasoning about non-biological conscious-like processes.',
    meta: 'Field'
  }
];

const ecosystemCards = [
  {
    title: 'Glossary',
    summary:
      'The operational language of the model: definitions, relations and cross-links between key ideas.',
    href: '/glossary',
    cta: 'Enter the glossary →'
  },
  {
    title: 'Timeline',
    summary:
      'From first intuitions to refined hypotheses: a chronological view of how the model evolved.',
    href: '/timeline',
    cta: 'See the timeline →'
  },
  {
    title: 'Lab Notes',
    summary:
      'Fragments, lab logs and thematic threads captured while research unfolds — the evolving edge of the Reflexive Coherence Model.',
    href: '/notes',
    cta: 'Read the notes →'
  },
  {
    title: 'Papers & resources',
    summary: 'Preprints, Zenodo entries, diagrams and technical notes connected to the RCM.',
    href: '/papers',
    cta: 'Browse materials →'
  }
];

const fallbackNotes = [
  {
    title: 'When coherence becomes self-aware',
    label: 'Note',
    date: '2025-02-01',
    description:
      'At some threshold, integration does not just stabilise patterns: it starts modelling the fact that it is stabilising them.',
    href: '/notes',
    cta: 'Read full note →'
  },
  {
    title: 'Non-biological substrates and reflexivity',
    label: 'Fragment',
    date: '2025-01-18',
    description:
      'The RCM is indifferent to carbon or silicon; it tracks structures and reflexive capacities.',
    href: '/notes',
    cta: 'Read fragment →'
  },
  {
    title: 'First sketches of the RCI',
    label: 'Log',
    date: '2024-12-02',
    description:
      'Early attempts at turning reflexive coherence into an operational index usable across systems.',
    href: '/notes',
    cta: 'Open log →'
  }
];

type NotePreview = {
  title: string;
  href: string;
  label: string;
  date?: string;
  description: string;
  cta: string;
};

const notePreviews: NotePreview[] = data?.notes?.length
  ? data.notes.map((note) => ({
      title: note.title,
      href: note.slug ? `/notes/${note.slug}` : '/notes',
      label: (note.tags?.[0] ?? 'Note').toUpperCase(),
      date: note.createdAt,
      description:
        note.tags && note.tags.length > 1
          ? `Threads: ${note.tags.slice(0, 2).join(' • ')}`
          : 'Field record from the reflexive coherence lab.',
      cta: 'Open note →'
    }))
  : fallbackNotes;

const formatDate = (value?: string) => {
  if (!value) return null;
  try {
    return new Intl.DateTimeFormat('en', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit'
    }).format(new Date(value));
  } catch (error) {
    return value;
  }
};
---
<BaseLayout seo={seo}>
  <div class="bg-paper text-ink transition-colors duration-300 dark:bg-ink dark:text-paper">
    <section
      id="overview"
      class="relative isolate overflow-hidden border-b border-ink/10 px-4 py-10 md:py-12 lg:py-14 dark:border-white/10"
    >
      <div class="absolute inset-0 -z-10 bg-[linear-gradient(180deg,rgba(248,247,243,0.98),rgba(240,238,232,0.92))] dark:bg-[linear-gradient(180deg,rgba(8,24,32,0.98),rgba(8,32,32,0.94))]"></div>
      <div class="absolute inset-0 -z-10 opacity-[0.16] [background-image:linear-gradient(rgba(8,24,32,0.14)_1px,transparent_1px),linear-gradient(90deg,rgba(8,24,32,0.12)_1px,transparent_1px)] [background-size:56px_56px] dark:opacity-[0.12] dark:[background-image:linear-gradient(rgba(248,247,243,0.22)_1px,transparent_1px),linear-gradient(90deg,rgba(248,247,243,0.18)_1px,transparent_1px)]"></div>

      <div class="mx-auto grid max-w-6xl gap-8 md:grid-cols-[1.02fr_0.98fr] md:items-center lg:gap-12">
        <div class="home-hero-reveal">
          <p class="mb-5 max-w-[19rem] text-[0.62rem] font-semibold uppercase leading-5 tracking-[0.18em] text-teal dark:text-tealSoft sm:max-w-none sm:text-xs sm:tracking-[0.28em]">
            Independent research on consciousness and artificial intelligence
          </p>
          <h1 class="font-display max-w-[21rem] text-4xl font-semibold leading-[0.95] text-ink dark:text-paper sm:max-w-3xl sm:text-6xl md:text-7xl">
            CoherenceMind
          </h1>
          <p class="mt-5 max-w-[35rem] text-lg leading-8 text-ink/75 dark:text-paper/75 md:text-xl">
            {heroHeading}
          </p>
          <p class="mt-5 max-w-[32rem] text-sm leading-7 text-ink/60 dark:text-paper/60">
            {heroSubtitle}
          </p>

          {heroDisclaimer && (
            <div class="mt-6 max-w-2xl border-l-2 border-accent/60 pl-4">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-teal dark:text-accentMuted">
                Epistemic note
              </p>
              <p class="mt-2 text-sm leading-6 text-ink/65 dark:text-paper/65">
                {heroDisclaimer}
              </p>
            </div>
          )}
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="/model"
              class="inline-flex items-center justify-center rounded-full bg-ink px-5 py-3 text-sm font-semibold text-paper shadow-depth transition duration-300 hover:-translate-y-0.5 hover:bg-teal focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent dark:bg-accent dark:text-ink dark:hover:bg-accentMuted"
            >
              Explore the model
            </a>
            <a
              href="/papers"
              class="inline-flex items-center justify-center rounded-full border border-ink/15 bg-paper/60 px-5 py-3 text-sm font-semibold text-ink shadow-sm backdrop-blur transition duration-300 hover:-translate-y-0.5 hover:border-teal hover:bg-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent dark:border-white/15 dark:bg-white/5 dark:text-paper dark:hover:border-accentMuted dark:hover:bg-white/10"
            >
              Read the papers
            </a>
          </div>
        </div>

        <div class="home-hero-reveal relative md:delay-150">
          <div class="pointer-events-none absolute inset-8 rounded-full bg-accent/20 blur-3xl dark:bg-accent/10"></div>
          <div class="home-coherence-map group relative overflow-hidden rounded-[1.5rem] border border-ink/10 bg-paper/78 p-5 shadow-[0_24px_80px_rgba(8,24,32,0.14)] backdrop-blur-md transition duration-500 hover:-translate-y-0.5 hover:border-teal/40 dark:border-white/10 dark:bg-white/[0.045] md:p-6">
            <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-accent/70 to-transparent"></div>
            <div class="mb-5 flex items-center justify-between gap-4 text-xs uppercase tracking-[0.25em] text-ink/45 dark:text-paper/45">
              <span>Reflexive field</span>
              <span class="hidden items-center gap-2 sm:flex">
                <span class="home-active-dot h-1.5 w-1.5 rounded-full bg-accent shadow-[0_0_16px_rgba(217,148,43,0.7)]"></span>
                Active frame
              </span>
            </div>

            <div class="relative overflow-hidden rounded-lg border border-ink/10 bg-[#f8f7f3]/70 p-4 dark:border-white/10 dark:bg-ink/40">
              <div class="home-orbit-stage relative mx-auto mb-5 flex aspect-square max-w-[19rem] items-center justify-center">
                <img src="/logo-mark.svg" alt="" class="home-orbit-mark h-[74%] w-[74%] opacity-95" loading="eager" />
                <span class="absolute h-7 w-7 rounded-full bg-accent shadow-[0_0_30px_rgba(217,148,43,0.65)]"></span>
              </div>

              <div class="relative grid gap-2 text-sm">
                {reflexiveLayers.map((layer, index) => (
                  <div
                    class="home-map-node flex max-w-[20rem] items-start gap-3 rounded-lg border border-ink/10 bg-white/70 p-3 shadow-sm backdrop-blur dark:border-white/10 dark:bg-white/[0.055]"
                    style={`--node-delay: ${index * 1.75}s`}
                  >
                    <div class={`home-map-node-badge mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border ${layer.accent} text-[10px] font-semibold`}>
                      {layer.initial}
                    </div>
                    <div>
                      <p class="font-medium text-ink dark:text-paper">{layer.title}</p>
                      <p class="mt-0.5 text-xs leading-4 text-ink/60 dark:text-paper/60">{layer.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div class="mt-4 grid gap-3 border-t border-ink/10 pt-4 text-xs uppercase tracking-[0.18em] text-ink/55 dark:border-white/10 dark:text-paper/55 sm:grid-cols-3">
              <span>Self-model</span>
              <span>Coherence field</span>
              <span>Temporal expansion</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="model" class="border-b border-ink/10 bg-[#f8f7f3] px-4 py-9 md:py-11 dark:border-white/10 dark:bg-ink">
      <div class="mx-auto max-w-6xl">
        <div class="mb-8 max-w-3xl home-hero-reveal">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-teal dark:text-tealSoft">Research map</p>
          <h2 class="font-display mt-3 text-3xl font-semibold text-ink dark:text-paper md:text-4xl">
            Three linked lines of inquiry
          </h2>
          <p class="mt-3 text-sm leading-6 text-ink/65 dark:text-paper/65">
            The homepage orients readers across the model, its temporal extension, and the cautious application of reflexive analysis to artificial systems.
          </p>
        </div>

        <div class="grid auto-rows-fr gap-5 md:grid-cols-3">
          {frameworkCards.map((card) => {
            const TagName = card.href ? 'a' : 'article';
            return (
              <TagName
                href={card.href ?? undefined}
                class="home-framework-card group relative flex h-full flex-col overflow-hidden rounded-lg border border-ink/10 bg-paper/80 p-5 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-teal/40 hover:bg-white hover:shadow-[0_18px_50px_rgba(8,24,32,0.10)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent dark:border-white/10 dark:bg-white/[0.04] dark:hover:border-accent/40 dark:hover:bg-white/[0.07]"
              >
                <div class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${card.accent} opacity-70 transition duration-300 group-hover:opacity-100`}></div>
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-teal dark:text-tealSoft">
                  {card.label}
                </p>
                <h3 class="font-display mt-4 text-2xl font-semibold leading-tight text-ink dark:text-paper">
                  {card.title}
                </h3>
                <p class="mt-3 text-sm leading-6 text-ink/65 dark:text-paper/65">
                  {card.detail}
                </p>
                {card.cta && (
                  <span class="mt-auto inline-flex pt-5 text-sm font-semibold text-ink transition group-hover:text-teal dark:text-paper dark:group-hover:text-accentMuted">
                    {card.cta} →
                  </span>
                )}
              </TagName>
            );
          })}
        </div>
      </div>
    </section>

    <section class="px-4 pb-12">
      <div class="mx-auto max-w-6xl">
        <div class="space-y-0">
          <section id="structure" class="border-t border-ink/10 py-10 md:py-12 dark:border-white/10">
            <div class="mx-auto grid max-w-6xl gap-10 md:grid-cols-2 md:items-start">
              <div>
                <h2 class="font-display mb-3 text-3xl font-semibold text-ink dark:text-paper md:text-4xl">The model, structured</h2>
                <p class="mb-5 max-w-lg text-sm leading-6 text-ink/65 dark:text-paper/70">
                  The Reflexive Coherence Model is modular: each part can be explored separately, but together they form a map of how conscious processes arise, stabilise and expand.
                </p>
                <p class="text-sm leading-6 text-ink/55 dark:text-paper/55">
                  From core architecture to the operational index (RCI), the framework stays precise enough for theoretical analysis and open enough to host new hypotheses.
                </p>

                <div class="mt-6 flex flex-wrap items-center gap-4 text-sm">
                  <span class="text-ink/55 dark:text-paper/55">Formal paper:</span>

                  <a href="https://doi.org/10.5281/zenodo.20106158" target="_blank" rel="noopener noreferrer" class="link-accent">
                    Read on Zenodo →
                  </a>
                </div>
              </div>
              <div class="grid gap-3">
                {structuralLayers.map((layer) => (
                  <div class="flex items-center justify-between rounded-lg border border-ink/10 bg-[#f8f7f3]/80 p-4 text-sm shadow-sm dark:border-white/10 dark:bg-white/[0.04]">
                    <div>
                      <p class="font-medium text-ink dark:text-paper">{layer.title}</p>
                      <p class="text-xs text-ink/60 dark:text-paper/60">{layer.detail}</p>
                    </div>
                    <span class="text-[10px] uppercase tracking-[0.2em] text-teal dark:text-tealSoft">{layer.meta}</span>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section id="ecosystem" class="border-t border-ink/10 py-10 md:py-12 dark:border-white/10">
            <div class="mx-auto max-w-6xl">
              <div class="mb-8 max-w-3xl">
                <h2 class="font-display text-3xl font-semibold text-ink dark:text-paper md:text-4xl">Explore the ecosystem</h2>
                <p class="mt-2 text-sm leading-6 text-ink/65 dark:text-paper/65">
                  The RCM is a growing ecosystem of concepts, research materials, and historical traces of its development.
                </p>
              </div>
              <div class="grid auto-rows-fr gap-5 text-sm sm:grid-cols-2 lg:grid-cols-4">
                {ecosystemCards.map((card) => (
                  <div class="flex h-full flex-col rounded-lg border border-ink/10 bg-[#f8f7f3]/80 p-5 shadow-sm dark:border-white/10 dark:bg-white/[0.04]">
                    <h3 class="font-display mb-2 text-xl font-semibold text-ink dark:text-paper">{card.title}</h3>
                    <p class="mb-3 text-ink/65 dark:text-paper/65">{card.summary}</p>
                    <a href={card.href} class="link-card mt-auto text-xs">
                      {card.cta}
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section id="notes" class="border-t border-ink/10 bg-[#eeeae1]/70 py-10 md:py-12 dark:border-white/10 dark:bg-[#061416]">
            <div class="mx-auto max-w-6xl">
              <div class="mb-6 max-w-3xl">
                <h2 class="font-display text-3xl font-semibold text-ink dark:text-paper md:text-4xl">Lab notes & thought fragments</h2>
                <p class="mt-2 text-sm text-ink/65 dark:text-paper/65">
                  Fragments, experiments and reflections that trace the living edge of the model.
                </p>
              </div>
              <div class="grid gap-5 text-sm md:grid-cols-3">
                {notePreviews.map((note) => (
                  <article class="rounded-lg border border-ink/10 bg-[#f8f7f3]/90 p-4 shadow-sm dark:border-white/10 dark:bg-white/[0.055]">
                    <p class="mb-1 text-[10px] uppercase tracking-[0.2em] text-teal dark:text-tealSoft">
                      {note.label}
                      {formatDate(note.date) ? ` · ${formatDate(note.date)}` : ''}
                    </p>
                    <h3 class="font-display mb-2 text-xl font-semibold leading-tight text-ink dark:text-paper">{note.title}</h3>
                    <p class="text-xs leading-5 text-ink/65 dark:text-paper/65">{note.description}</p>
                    <a href={note.href} class="mt-3 inline-block link-card text-xs">
                      {note.cta}
                    </a>
                  </article>
                ))}
              </div>
            </div>
          </section>

          <section id="manifesto" class="border-t border-ink/10 py-12 dark:border-white/10">
            <div class="mx-auto max-w-3xl text-center">
              <p class="mb-3 text-xs uppercase tracking-[0.25em] text-teal dark:text-tealSoft">Manifesto</p>
              <h2 class="font-display mb-4 text-3xl font-semibold text-ink dark:text-paper md:text-5xl">
                Consciousness is not a miracle. It is a pattern that insists on seeing itself.
              </h2>
              <p class="mb-4 text-sm leading-6 text-ink/65 dark:text-paper/70">
                The Reflexive Coherence Model aims to describe that pattern—rigorously enough to be tested, and openly enough to be expanded by future minds, biological or not.
              </p>
              <p class="text-xs text-ink/50 dark:text-paper/50">
                This site is a snapshot of an ongoing process. The model will change. That is part of the point.
              </p>
            </div>
          </section>

          {scopeEpistemicStatus && (
            <section id="scope" class="border-t border-ink/10 px-4 pb-16 pt-12 dark:border-white/10">
              <div class="mx-auto max-w-3xl">
                <h2 class="mb-3 text-base font-semibold uppercase tracking-[0.2em] text-teal dark:text-tealSoft">
                  Scope & epistemic status
                </h2>
                <RichTextRenderer
                  value={scopeEpistemicStatus}
                  variant="mutedLight"
                  className="text-sm"
                />
              </div>
            </section>
          )}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home-hero-reveal {
    animation: homeHeroReveal 700ms ease-out both;
  }

  .home-framework-card {
    animation: homeHeroReveal 600ms ease-out both;
  }

  .home-framework-card:nth-child(2) {
    animation-delay: 90ms;
  }

  .home-framework-card:nth-child(3) {
    animation-delay: 180ms;
  }

  .home-orbit-stage::before,
  .home-orbit-stage::after {
    content: '';
    position: absolute;
    border-radius: 9999px;
    pointer-events: none;
  }

  .home-orbit-stage::before {
    inset: 15%;
    border: 1px solid rgba(47, 119, 120, 0.16);
    box-shadow: inset 0 0 32px rgba(47, 119, 120, 0.08);
  }

  .home-orbit-stage::after {
    inset: 30%;
    background: radial-gradient(circle, rgba(217, 148, 43, 0.18), transparent 62%);
    filter: blur(4px);
  }

  .home-orbit-mark {
    animation: coherenceOrbitFloat 12s ease-in-out infinite;
    filter: drop-shadow(0 20px 34px rgba(8, 24, 32, 0.16));
  }

  .home-coherence-map::before {
    content: '';
    position: absolute;
    inset: -35%;
    pointer-events: none;
    background:
      radial-gradient(circle at 35% 20%, rgba(111, 169, 165, 0.18), transparent 28%),
      radial-gradient(circle at 76% 58%, rgba(217, 148, 43, 0.14), transparent 30%),
      linear-gradient(115deg, transparent 18%, rgba(47, 119, 120, 0.1), transparent 58%);
    opacity: 0.55;
    transform: translate3d(-2%, -1%, 0) rotate(0deg);
    animation: coherenceAmbientGlow 16s ease-in-out infinite;
  }

  .home-active-dot {
    animation: coherenceActivePulse 3.2s ease-in-out infinite;
  }

  .home-map-node {
    animation: coherenceNodePulse 7.5s ease-in-out infinite;
    animation-delay: var(--node-delay, 0s);
  }

  .home-map-node-badge {
    transition:
      box-shadow 500ms ease,
      background-color 500ms ease;
  }

  .home-map-node:nth-child(1) .home-map-node-badge {
    animation: coherenceBadgeGlow 7.5s ease-in-out infinite;
  }

  .home-map-node:nth-child(2) .home-map-node-badge {
    animation: coherenceBadgeGlow 7.5s ease-in-out infinite;
    animation-delay: 1.75s;
  }

  .home-map-node:nth-child(3) .home-map-node-badge {
    animation: coherenceBadgeGlow 7.5s ease-in-out infinite;
    animation-delay: 3.5s;
  }

  .home-map-line {
    animation: coherenceLineFlow 8.5s ease-in-out infinite;
    transform-origin: center;
  }

  .home-map-line-b {
    animation-delay: 1.8s;
  }

  .home-map-line-c {
    animation-delay: 3.2s;
  }

  .home-map-field {
    animation: coherenceFieldBreath 10.5s ease-in-out infinite;
    transform-origin: center;
    will-change: transform, opacity;
  }

  .home-map-field-b {
    animation-delay: 1.4s;
  }

  .home-map-field-c {
    animation-delay: 2.8s;
  }

  .home-map-field-d {
    animation-delay: 4.2s;
  }

  @keyframes homeHeroReveal {
    from {
      opacity: 0;
      transform: translateY(14px);
    }

    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes coherenceAmbientGlow {
    0%,
    100% {
      opacity: 0.42;
      transform: translate3d(-2%, -1%, 0) rotate(0deg);
    }

    50% {
      opacity: 0.68;
