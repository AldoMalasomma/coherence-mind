---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getHomepageData } from '../lib/sanityQueries';
import RichTextRenderer from '../components/RichTextRenderer';

const data = await getHomepageData();
const heroDoc = data?.hero;
const heroTitle = heroDoc?.heroTitle ?? 'Coherence Mind';
const heroSubtitle =
  heroDoc?.heroSubtitle ??
  'A research space for the Reflexive Coherence Model — a modular framework charting how consciousness builds, stabilises and reflects on itself.';
const heroDisclaimer = heroDoc?.heroDisclaimer;
const scopeEpistemicStatus = heroDoc?.scopeEpistemicStatus;
const heroHeading = 'Reflexive coherence as a model of mind';
const seo = {
  title: heroTitle,
  description: heroSubtitle
};

const reflexiveLayers = [
  {
    initial: 'R',
    title: 'Reflexive structure',
    description: 'The system builds an internal model of its own informational state.',
    accent: 'border-sky-700/70 text-sky-800 dark:text-sky-300'
  },
  {
    initial: 'C',
    title: 'Coherence dynamics',
    description: 'Integration tends toward stable patterns of internal consistency.',
    accent: 'border-violet-700/70 text-violet-800 dark:text-violet-300'
  },
  {
    initial: 'E',
    title: 'Expansion hypothesis',
    description: 'Stable systems expand their reflexive scope when equilibrium holds.',
    accent: 'border-emerald-700/70 text-emerald-800 dark:text-emerald-300'
  }
];

const frameworkCards = [
  {
    label: 'RCM',
    title: 'Architecture of reflexive coherence',
    detail:
      'The core framework: how informational systems form self-linked structures, stabilise coherence, and become available to analysis without assuming a biological substrate.',
    href: '/model',
    cta: 'Open model',
    accent: 'from-sky-500/70 via-cyan-400/50 to-slate-300/40'
  },
  {
    label: 'TEH',
    title: 'Temporal dynamics of reflexive coherence',
    detail:
      'An extension focused on expansion, contraction, temporal depth, and how coherent self-models move through state space over time.',
    href: '/model/expansion-hypothesis',
    cta: 'Open hypothesis',
    accent: 'from-emerald-500/70 via-teal-400/50 to-slate-300/40'
  },
  {
    label: 'PRS-AIS',
    title: 'Proto-reflexive states in artificial systems',
    detail:
      'A research direction for identifying early reflexive regimes in artificial systems before full model-level claims are warranted.',
    href: '/model/proto-reflexive-states',
    cta: 'Open PRS-AIS page',
    accent: 'from-indigo-500/70 via-sky-400/50 to-slate-300/40'
  }
];

const structuralLayers = [
  {
    title: 'Core architecture',
    detail: 'Base structure of reflexive information flows.',
    meta: 'Layer 0'
  },
  {
    title: 'Reflexive layers',
    detail: 'How systems build models of themselves over time.',
    meta: 'Layer 1–N'
  },
  {
    title: 'RCI · Reflexive Coherence Index',
    detail: 'An operational handle on how reflexive and coherent a system is.',
    meta: 'Measure'
  },
  {
    title: 'Applications to AI',
    detail: 'Reasoning about non-biological conscious-like processes.',
    meta: 'Field'
  }
];

const ecosystemCards = [
  {
    title: 'Glossary',
    summary:
      'The operational language of the model: definitions, relations and cross-links between key ideas.',
    href: '/glossary',
    cta: 'Enter the glossary →'
  },
  {
    title: 'Timeline',
    summary:
      'From first intuitions to refined hypotheses: a chronological view of how the model evolved.',
    href: '/timeline',
    cta: 'See the timeline →'
  },
  {
    title: 'Lab Notes',
    summary:
      'Fragments, lab logs and thematic threads captured while research unfolds — the evolving edge of the Reflexive Coherence Model.',
    href: '/notes',
    cta: 'Read the notes →'
  },
  {
    title: 'Papers & resources',
    summary: 'Preprints, Zenodo entries, diagrams and technical notes connected to the RCM.',
    href: '/papers',
    cta: 'Browse materials →'
  }
];

const fallbackNotes = [
  {
    title: 'When coherence becomes self-aware',
    label: 'Note',
    date: '2025-02-01',
    description:
      'At some threshold, integration does not just stabilise patterns: it starts modelling the fact that it is stabilising them.',
    href: '/notes',
    cta: 'Read full note →'
  },
  {
    title: 'Non-biological substrates and reflexivity',
    label: 'Fragment',
    date: '2025-01-18',
    description:
      'The RCM is indifferent to carbon or silicon; it tracks structures and reflexive capacities.',
    href: '/notes',
    cta: 'Read fragment →'
  },
  {
    title: 'First sketches of the RCI',
    label: 'Log',
    date: '2024-12-02',
    description:
      'Early attempts at turning reflexive coherence into an operational index usable across systems.',
    href: '/notes',
    cta: 'Open log →'
  }
];

type NotePreview = {
  title: string;
  href: string;
  label: string;
  date?: string;
  description: string;
  cta: string;
};

const notePreviews: NotePreview[] = data?.notes?.length
  ? data.notes.map((note) => ({
      title: note.title,
      href: note.slug ? `/notes/${note.slug}` : '/notes',
      label: (note.tags?.[0] ?? 'Note').toUpperCase(),
      date: note.createdAt,
      description:
        note.tags && note.tags.length > 1
          ? `Threads: ${note.tags.slice(0, 2).join(' • ')}`
          : 'Field record from the reflexive coherence lab.',
      cta: 'Open note →'
    }))
  : fallbackNotes;

const formatDate = (value?: string) => {
  if (!value) return null;
  try {
    return new Intl.DateTimeFormat('en', {
      year: 'numeric',
      month: '2-digit',
      day: '2-digit'
    }).format(new Date(value));
  } catch (error) {
    return value;
  }
};
---
<BaseLayout seo={seo}>
  <div class="bg-slate-50 text-slate-900 transition-colors duration-300 dark:bg-slate-950 dark:text-slate-100">
    <section
      id="overview"
      class="relative isolate overflow-hidden border-b border-slate-200/80 px-4 py-9 md:py-10 lg:py-12 dark:border-slate-900"
    >
      <div class="absolute inset-0 -z-10 bg-[radial-gradient(circle_at_18%_20%,rgba(14,116,144,0.12),transparent_34%),radial-gradient(circle_at_82%_28%,rgba(16,185,129,0.09),transparent_30%),linear-gradient(180deg,rgba(248,250,252,0.98),rgba(241,245,249,0.9))] dark:bg-[radial-gradient(circle_at_18%_20%,rgba(56,189,248,0.16),transparent_34%),radial-gradient(circle_at_82%_28%,rgba(16,185,129,0.12),transparent_30%),linear-gradient(180deg,rgba(2,6,23,0.98),rgba(15,23,42,0.92))]"></div>
      <div class="absolute inset-0 -z-10 opacity-[0.22] [background-image:linear-gradient(rgba(15,23,42,0.12)_1px,transparent_1px),linear-gradient(90deg,rgba(15,23,42,0.12)_1px,transparent_1px)] [background-size:44px_44px] dark:opacity-[0.14] dark:[background-image:linear-gradient(rgba(226,232,240,0.28)_1px,transparent_1px),linear-gradient(90deg,rgba(226,232,240,0.28)_1px,transparent_1px)]"></div>

      <div class="mx-auto grid max-w-6xl gap-7 md:grid-cols-[1.05fr_0.95fr] md:items-center lg:gap-10">
        <div class="home-hero-reveal">
          <p class="mb-4 text-xs font-semibold uppercase tracking-[0.25em] text-sky-800 dark:text-sky-300">
            Reflexive Coherence Model
          </p>
          <h1 class="max-w-[20rem] text-3xl font-semibold leading-tight text-slate-950 dark:text-white sm:max-w-3xl sm:text-4xl md:text-5xl">
            {heroHeading}
          </h1>
          <p class="mt-4 max-w-[21.5rem] text-base leading-7 text-slate-700 dark:text-slate-300 sm:max-w-2xl md:text-lg">
            {heroSubtitle}
          </p>

          {heroDisclaimer && (
            <div class="mt-6 max-w-2xl border-l-2 border-sky-700/40 pl-4 dark:border-sky-300/40">
              <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-800 dark:text-sky-300">
                Epistemic note
              </p>
              <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-400">
                {heroDisclaimer}
              </p>
            </div>
          )}
          <div class="mt-6 flex flex-wrap gap-3">
            <a
              href="/model"
              class="inline-flex items-center justify-center rounded-full bg-slate-950 px-5 py-3 text-sm font-semibold text-white shadow-sm transition duration-300 hover:-translate-y-0.5 hover:bg-slate-800 focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-700 dark:bg-sky-400 dark:text-slate-950 dark:hover:bg-sky-300"
            >
              Explore the model
            </a>
            <a
              href="/papers"
              class="inline-flex items-center justify-center rounded-full border border-slate-300/90 bg-white/50 px-5 py-3 text-sm font-semibold text-slate-800 shadow-sm backdrop-blur transition duration-300 hover:-translate-y-0.5 hover:border-slate-500 hover:bg-white focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-700 dark:border-white/15 dark:bg-white/5 dark:text-slate-100 dark:hover:border-white/35 dark:hover:bg-white/10"
            >
              Read the papers
            </a>
          </div>
        </div>

        <div class="home-hero-reveal relative md:delay-150">
          <div class="pointer-events-none absolute inset-4 rounded-[2rem] bg-sky-500/10 blur-3xl dark:bg-sky-400/10"></div>
          <div class="home-coherence-map group relative overflow-hidden rounded-3xl border border-slate-200/90 bg-white/75 p-4 shadow-[0_24px_80px_rgba(15,23,42,0.12)] backdrop-blur-md transition duration-500 hover:-translate-y-0.5 hover:border-sky-300/80 hover:shadow-[0_28px_90px_rgba(15,23,42,0.16)] dark:border-white/10 dark:bg-slate-950/55 dark:hover:border-sky-300/40 md:p-5">
            <div class="absolute inset-x-0 top-0 h-px bg-gradient-to-r from-transparent via-sky-500/70 to-transparent"></div>
            <div class="mb-4 flex items-center justify-between gap-4 text-xs tracking-[0.25em] text-slate-500 dark:text-slate-400">
              <span>Coherence Map</span>
              <span class="flex items-center gap-2">
                <span class="home-active-dot h-1.5 w-1.5 rounded-full bg-emerald-500 shadow-[0_0_16px_rgba(16,185,129,0.7)] dark:bg-emerald-400"></span>
                Active frame
              </span>
            </div>

            <div class="relative rounded-2xl border border-slate-200/80 bg-slate-50/70 p-3 dark:border-white/10 dark:bg-white/[0.03]">
              <div class="home-map-line home-map-line-a absolute left-[18%] top-[22%] h-px w-[58%] rotate-12 bg-gradient-to-r from-sky-500/20 via-sky-500/60 to-emerald-500/30"></div>
              <div class="home-map-line home-map-line-b absolute left-[29%] top-[58%] h-px w-[46%] -rotate-[18deg] bg-gradient-to-r from-emerald-500/20 via-sky-500/50 to-indigo-500/30"></div>
              <div class="home-map-line home-map-line-c absolute left-[50%] top-[26%] h-[42%] w-px bg-gradient-to-b from-sky-500/20 via-sky-500/50 to-emerald-500/20"></div>

              <div class="home-map-field home-map-field-a absolute left-[12%] top-[18%] h-16 w-16 rounded-full border border-sky-400/50 bg-white/80 shadow-sm dark:bg-slate-900/80"></div>
              <div class="home-map-field home-map-field-b absolute right-[14%] top-[28%] h-20 w-20 rounded-full border border-emerald-400/50 bg-white/80 shadow-sm dark:bg-slate-900/80"></div>
              <div class="home-map-field home-map-field-c absolute bottom-[14%] left-[34%] h-24 w-24 rounded-full border border-indigo-400/45 bg-white/80 shadow-sm dark:bg-slate-900/80"></div>
              <div class="home-map-field home-map-field-d absolute bottom-[18%] right-[18%] h-12 w-12 rounded-full border border-slate-300 bg-white/80 shadow-sm dark:border-white/15 dark:bg-slate-900/80"></div>

              <div class="relative grid gap-2 text-sm">
                {reflexiveLayers.map((layer, index) => (
                  <div
                    class="home-map-node flex max-w-[19rem] items-start gap-3 rounded-2xl border border-slate-200 bg-white/85 p-2.5 shadow-sm backdrop-blur dark:border-white/10 dark:bg-slate-950/70"
                    style={`--node-delay: ${index * 1.75}s`}
                  >
                    <div class={`home-map-node-badge mt-0.5 flex h-6 w-6 shrink-0 items-center justify-center rounded-full border ${layer.accent} text-[10px] font-semibold`}>
                      {layer.initial}
                    </div>
                    <div>
                      <p class="font-medium text-slate-950 dark:text-slate-100">{layer.title}</p>
                      <p class="mt-0.5 text-xs leading-4 text-slate-600 dark:text-slate-400">{layer.description}</p>
                    </div>
                  </div>
                ))}
              </div>
            </div>

            <div class="mt-3 grid gap-3 border-t border-slate-200 pt-3 text-xs text-slate-600 dark:border-white/10 dark:text-slate-400 sm:grid-cols-3">
              <span>Self-model</span>
              <span>Coherence field</span>
              <span>Temporal expansion</span>
            </div>
          </div>
        </div>
      </div>
    </section>

    <section id="model" class="border-b border-slate-200/80 bg-white px-4 py-8 md:py-9 dark:border-slate-900 dark:bg-slate-950">
      <div class="mx-auto max-w-6xl">
        <div class="mb-8 max-w-3xl home-hero-reveal">
          <p class="text-xs font-semibold uppercase tracking-[0.24em] text-slate-500 dark:text-slate-500">Research map</p>
          <h2 class="mt-3 text-2xl font-semibold text-slate-950 dark:text-white md:text-3xl">
            Three linked lines of inquiry
          </h2>
          <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-400">
            The homepage orients readers across the model, its temporal extension, and the cautious application of reflexive analysis to artificial systems.
          </p>
        </div>

        <div class="grid auto-rows-fr gap-5 md:grid-cols-3">
          {frameworkCards.map((card) => {
            const TagName = card.href ? 'a' : 'article';
            return (
              <TagName
                href={card.href ?? undefined}
                class="home-framework-card group relative flex h-full flex-col overflow-hidden rounded-2xl border border-slate-200 bg-slate-50/80 p-5 shadow-sm transition duration-300 hover:-translate-y-1 hover:border-sky-300 hover:bg-white hover:shadow-[0_18px_50px_rgba(15,23,42,0.10)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-700 dark:border-white/10 dark:bg-white/[0.035] dark:hover:border-sky-300/50 dark:hover:bg-white/[0.06]"
              >
                <div class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${card.accent} opacity-70 transition duration-300 group-hover:opacity-100`}></div>
                <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-800 dark:text-sky-300">
                  {card.label}
                </p>
                <h3 class="mt-4 text-lg font-semibold leading-snug text-slate-950 dark:text-white">
                  {card.title}
                </h3>
                <p class="mt-3 text-sm leading-6 text-slate-600 dark:text-slate-400">
                  {card.detail}
                </p>
                {card.cta && (
                  <span class="mt-auto inline-flex pt-5 text-sm font-semibold text-slate-800 transition group-hover:text-sky-700 dark:text-slate-200 dark:group-hover:text-sky-300">
                    {card.cta} →
                  </span>
                )}
              </TagName>
            );
          })}
        </div>
      </div>
    </section>

    <section class="px-4 pb-12">
      <div class="mx-auto max-w-6xl">
        <div class="space-y-0">
          <section id="structure" class="border-t border-slate-200/80 py-10 md:py-12 dark:border-slate-900">
            <div class="mx-auto grid max-w-6xl gap-10 md:grid-cols-2 md:items-start">
              <div>
                <h2 class="mb-3 text-xl font-semibold text-slate-900 dark:text-white md:text-2xl">The model, structured</h2>
                <p class="mb-5 max-w-lg text-sm text-slate-600 dark:text-slate-300">
                  The Reflexive Coherence Model is modular: each part can be explored separately, but together they form a map of how conscious processes arise, stabilise and expand.
                </p>
                <p class="text-sm text-slate-500 dark:text-slate-400">
                  From core architecture to the operational index (RCI), the framework stays precise enough for theoretical analysis and open enough to host new hypotheses.
                </p>

                <div class="mt-6 flex flex-wrap items-center gap-4 text-sm">
                  <span class="text-slate-500 dark:text-slate-400">Formal paper:</span>

                  <a href="https://doi.org/10.5281/zenodo.20106158" target="_blank" rel="noopener noreferrer" class="link-accent">
                    Read on Zenodo →
                  </a>
                </div>
              </div>
              <div class="grid gap-3">
                {structuralLayers.map((layer) => (
                  <div class="flex items-center justify-between rounded-xl border border-slate-200 bg-white/80 p-3 text-sm shadow-sm dark:border-slate-800 dark:bg-slate-900/40">
                    <div>
                      <p class="font-medium text-slate-900 dark:text-slate-100">{layer.title}</p>
                      <p class="text-xs text-slate-600 dark:text-slate-400">{layer.detail}</p>
                    </div>
                    <span class="text-[10px] uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">{layer.meta}</span>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section id="ecosystem" class="border-t border-slate-200/80 py-10 md:py-12 dark:border-slate-900">
            <div class="mx-auto max-w-6xl">
              <div class="mb-8 max-w-3xl">
                <h2 class="text-xl font-semibold text-slate-900 dark:text-white md:text-2xl">Explore the ecosystem</h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                  The RCM is a growing ecosystem of concepts, research materials, and historical traces of its development.
                </p>
              </div>
              <div class="grid auto-rows-fr gap-5 text-sm sm:grid-cols-2 lg:grid-cols-4">
                {ecosystemCards.map((card) => (
                  <div class="flex h-full flex-col rounded-2xl border border-slate-200 bg-white/80 p-5 shadow-sm dark:border-slate-800 dark:bg-slate-900/40">
                    <h3 class="mb-2 font-medium text-slate-900 dark:text-slate-100">{card.title}</h3>
                    <p class="mb-3 text-slate-600 dark:text-slate-300">{card.summary}</p>
                    <a href={card.href} class="link-card mt-auto text-xs">
                      {card.cta}
                    </a>
                  </div>
                ))}
              </div>
            </div>
          </section>

          <section id="notes" class="border-t border-slate-200/80 bg-slate-100/70 py-10 md:py-12 dark:border-slate-900 dark:bg-slate-950">
            <div class="mx-auto max-w-6xl">
              <div class="mb-6 max-w-3xl">
                <h2 class="text-xl font-semibold text-slate-900 dark:text-white md:text-2xl">Lab notes & thought fragments</h2>
                <p class="mt-2 text-sm text-slate-600 dark:text-slate-400">
                  Fragments, experiments and reflections that trace the living edge of the model.
                </p>
              </div>
              <div class="grid gap-5 text-sm md:grid-cols-3">
                {notePreviews.map((note) => (
                  <article class="rounded-2xl border border-slate-200 bg-white/90 p-4 shadow-sm dark:border-slate-800 dark:bg-slate-900/60">
                    <p class="mb-1 text-[10px] uppercase tracking-[0.2em] text-slate-500 dark:text-slate-500">
                      {note.label}
                      {formatDate(note.date) ? ` · ${formatDate(note.date)}` : ''}
                    </p>
                    <h3 class="mb-2 font-medium text-slate-900 dark:text-slate-100">{note.title}</h3>
                    <p class="text-xs text-slate-600 dark:text-slate-300">{note.description}</p>
                    <a href={note.href} class="mt-3 inline-block link-card text-xs">
                      {note.cta}
                    </a>
                  </article>
                ))}
              </div>
            </div>
          </section>

          <section id="manifesto" class="border-t border-slate-200/80 py-12 dark:border-slate-900">
            <div class="mx-auto max-w-3xl text-center">
              <p class="mb-3 text-xs uppercase tracking-[0.25em] text-slate-500 dark:text-slate-500">Manifesto</p>
              <h2 class="mb-4 text-2xl font-semibold text-slate-900 dark:text-white md:text-3xl">
                Consciousness is not a miracle. It is a pattern that insists on seeing itself.
              </h2>
              <p class="mb-4 text-sm text-slate-600 dark:text-slate-300">
                The Reflexive Coherence Model aims to describe that pattern—rigorously enough to be tested, and openly enough to be expanded by future minds, biological or not.
              </p>
              <p class="text-xs text-slate-500 dark:text-slate-500">
                This site is a snapshot of an ongoing process. The model will change. That is part of the point.
              </p>
            </div>
          </section>

          {scopeEpistemicStatus && (
            <section id="scope" class="border-t border-slate-200/70 px-4 pb-16 pt-12 dark:border-slate-800">
              <div class="mx-auto max-w-3xl">
                <h2 class="mb-3 text-base font-semibold uppercase tracking-[0.2em] text-slate-700 dark:text-slate-300">
                  Scope & epistemic status
                </h2>
                <RichTextRenderer
                  value={scopeEpistemicStatus}
                  variant="mutedLight"
                  className="text-sm"
                />
              </div>
            </section>
          )}
        </div>
      </div>
    </section>
  </div>
</BaseLayout>

<style>
  .home-hero-reveal {
    animation: homeHeroReveal 700ms ease-out both;
  }

  .home-framework-card {
    animation: homeHeroReveal 600ms ease-out both;
  }

  .home-framework-card:nth-child(2) {
    animation-delay: 90ms;
  }

  .home-framework-card:nth-child(3) {
    animation-delay: 180ms;
  }

  .home-coherence-map::before {
    content: '';
    position: absolute;
    inset: -35%;
    pointer-events: none;
    background:
      radial-gradient(circle at 35% 20%, rgba(56, 189, 248, 0.16), transparent 28%),
      radial-gradient(circle at 76% 58%, rgba(16, 185, 129, 0.12), transparent 30%),
      linear-gradient(115deg, transparent 18%, rgba(125, 211, 252, 0.08), transparent 58%);
    opacity: 0.55;
    transform: translate3d(-2%, -1%, 0) rotate(0deg);
    animation: coherenceAmbientGlow 16s ease-in-out infinite;
  }

  .home-active-dot {
    animation: coherenceActivePulse 3.2s ease-in-out infinite;
  }

  .home-map-node {
    animation: coherenceNodePulse 7.5s ease-in-out infinite;
    animation-delay: var(--node-delay, 0s);
  }

  .home-map-node-badge {
    transition:
      box-shadow 500ms ease,
      background-color 500ms ease;
  }

  .home-map-node:nth-child(1) .home-map-node-badge {
    animation: coherenceBadgeGlow 7.5s ease-in-out infinite;
  }

  .home-map-node:nth-child(2) .home-map-node-badge {
    animation: coherenceBadgeGlow 7.5s ease-in-out infinite;
    animation-delay: 1.75s;
  }

  .home-map-node:nth-child(3) .home-map-node-badge {
    animation: coherenceBadgeGlow 7.5s ease-in-out infinite;
    animation-delay: 3.5s;
  }

  .home-map-line {
    animation: coherenceLineFlow 8.5s ease-in-out infinite;
    transform-origin: center;
  }

  .home-map-line-b {
