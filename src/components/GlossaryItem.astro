---
import type { Concept } from '../lib/types';
import type { PortableTextBlock } from '@portabletext/types';
import RichTextRenderer from './RichTextRenderer';

type GlossaryConcept = Concept & {
  summary?: string;
  definition?: string;
  what_is?: string;
  whatIsText?: string;
  whatNotText?: string;
};

const { concept } = Astro.props as { concept: GlossaryConcept };

const term = concept.term || concept.title || concept.name || concept.label || '';
const slug = concept.slug || (term ? term.toLowerCase().replace(/\s+/g, '-').replace(/[^a-z0-9\-]/g, '') : '');

const short = concept.shortDefinition ?? concept.summary ?? concept.definition ?? '';

const whatItIs = concept.whatItIs ?? concept.what_is ?? concept.whatIsText ?? '';
const whatItIsNot = concept.whatItIsNot ?? concept.what_is_not ?? concept.whatNotText ?? '';

const related = concept.relatedConcepts ?? [];

type PortableChild = { text?: string };

const blockToPlain = (block: PortableTextBlock): string => {
  const children = (block as PortableTextBlock & { children?: PortableChild[] }).children;
  return Array.isArray(children) ? children.map((child) => child?.text ?? '').join('').trim() : '';
};

const isRelatedOnlyBlock = (block: PortableTextBlock): boolean => {
  const text = blockToPlain(block);
  return /^related(?:\s+\(suggested\))?\s*:/i.test(text);
};

const visibleFullDefinition = Array.isArray(concept.fullDefinition)
  ? concept.fullDefinition.filter((block) => !isRelatedOnlyBlock(block))
  : undefined;

const normalizeRelatedLabel = (label: string): string =>
  label.replace(/Reflexive Causal Closure/g, 'Reflexive Causal Coupling');

const relatedLabels = related
  .map((r) => normalizeRelatedLabel(r.term ?? r.title ?? r.name ?? ''))
  .filter(Boolean);
---

<article
  class="rounded-2xl border border-slate-200 bg-white/80 p-6 shadow-sm backdrop-blur-sm dark:border-slate-800 dark:bg-slate-900/40"
  id={slug}
>
  <div class="flex items-start justify-between gap-4">
    <div>
      <h3 class="text-xl font-semibold text-slate-900 dark:text-white">{term}</h3>
      {short ? (
        <p class="mt-1 text-sm text-slate-600 dark:text-white/70">{short}</p>
      ) : null}
    </div>

    <button
      type="button"
      data-copy-link={slug}
      class="shrink-0 rounded-full border border-slate-200 bg-white/80 px-3 py-1 text-xs font-semibold text-slate-700 transition hover:bg-white focus:outline-none focus:ring-2 focus:ring-sky-300/50 dark:border-slate-800 dark:bg-slate-900/60 dark:text-slate-200 dark:hover:bg-slate-800 dark:focus:ring-sky-400/30"
      aria-label={`Copy link to ${term}`}
      title="Copy link"
    >
      Copy
    </button>
  </div>

  {/* Optional rich content (kept) */}
  {visibleFullDefinition?.length ? (
    <div class="prose prose-slate mt-4 max-w-none dark:prose-invert">
      <RichTextRenderer value={visibleFullDefinition} />
    </div>
  ) : null}

  {(whatItIs || whatItIsNot) && (
    <div class="mt-4 grid gap-3">
      {whatItIs && (
        <div class="rounded-2xl border border-slate-200 bg-white/90 p-4 text-sm dark:border-slate-800 dark:bg-slate-900/60">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-700 dark:text-white/70">What it is</p>
          <p class="mt-2 text-slate-700 dark:text-white/80">{whatItIs}</p>
        </div>
      )}

      {whatItIsNot && (
        <div class="rounded-2xl border border-slate-200 bg-white/90 p-4 text-sm dark:border-slate-800 dark:bg-slate-900/60">
          <p class="text-xs font-semibold uppercase tracking-wide text-slate-700 dark:text-white/70">What it is not</p>
          <p class="mt-2 text-slate-700 dark:text-white/80">{whatItIsNot}</p>
        </div>
      )}
    </div>
  )}

  {relatedLabels.length ? (
    <p class="pt-4 text-sm text-slate-600 dark:text-white/70">
      Related: {relatedLabels.join(', ')}
    </p>
  ) : null}
</article>
