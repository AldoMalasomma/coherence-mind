---
type FrameworkKey = 'rcm' | 'teh' | 'prs-ais';

type Props = {
  current?: FrameworkKey;
};

const { current } = Astro.props as Props;

const items: Array<{
  key: FrameworkKey;
  title: string;
  label: string;
  href: string;
  accent: string;
}> = [
  {
    key: 'rcm',
    title: 'RCM',
    label: 'Foundational architecture',
    href: '/model',
    accent: 'from-sky-500/70 via-cyan-400/50 to-slate-300/40'
  },
  {
    key: 'teh',
    title: 'TEH',
    label: 'Temporal dynamics',
    href: '/model/expansion-hypothesis',
    accent: 'from-emerald-500/70 via-teal-400/50 to-slate-300/40'
  },
  {
    key: 'prs-ais',
    title: 'PRS-AIS',
    label: 'Artificial systems',
    href: '/model/proto-reflexive-states',
    accent: 'from-indigo-500/70 via-sky-400/50 to-slate-300/40'
  }
];
---

<section class="scroll-mt-32">
  <div class="rounded-2xl border border-slate-200 bg-white/80 p-6 shadow-sm dark:border-slate-800 dark:bg-slate-900/40">
    <div class="flex flex-wrap items-end justify-between gap-4">
      <div>
        <h2 class="text-xl font-semibold text-slate-900 dark:text-white md:text-2xl">Explore the framework</h2>
        <p class="mt-2 text-sm leading-relaxed text-slate-600 dark:text-white/70">
          The three pages form a connected route through architecture, temporal dynamics, and artificial-system interpretation.
        </p>
      </div>
    </div>

    <div class="mt-6 grid gap-4 md:grid-cols-3">
      {items.map((item) => {
        const isCurrent = item.key === current;

        return isCurrent ? (
          <article
            aria-current="page"
            class="relative overflow-hidden rounded-2xl border border-sky-300 bg-white/90 p-5 shadow-sm dark:border-sky-300/40 dark:bg-white/[0.07]"
          >
            <div class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${item.accent} opacity-100`}></div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-800 dark:text-sky-300">
              {item.title}
            </p>
            <p class="mt-3 text-sm font-semibold text-slate-900 dark:text-white">{item.label}</p>
            <p class="mt-4 text-xs font-semibold uppercase tracking-wide text-slate-500 dark:text-white/50">
              Current page
            </p>
          </article>
        ) : (
          <a
            href={item.href}
            class="group relative overflow-hidden rounded-2xl border border-slate-200 bg-white/90 p-5 shadow-sm transition duration-300 hover:-translate-y-0.5 hover:border-sky-300 hover:shadow-[0_14px_40px_rgba(15,23,42,0.10)] focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-sky-700 motion-reduce:transition-none motion-reduce:hover:translate-y-0 dark:border-slate-800 dark:bg-slate-900/60 dark:hover:border-sky-300/50"
          >
            <div class={`absolute inset-x-0 top-0 h-1 bg-gradient-to-r ${item.accent} opacity-70 transition duration-300 group-hover:opacity-100`}></div>
            <p class="text-xs font-semibold uppercase tracking-[0.24em] text-sky-800 dark:text-sky-300">
              {item.title}
            </p>
            <p class="mt-3 text-sm font-semibold text-slate-900 dark:text-white">{item.label}</p>
            <p class="mt-4 text-xs font-semibold text-slate-700 transition group-hover:text-sky-700 dark:text-white/70 dark:group-hover:text-sky-300">
              Open page →
            </p>
          </a>
        );
      })}
    </div>
  </div>
</section>
