---
interface Props {
  analyticsId: string;
  policyHref?: string;
}

const { analyticsId, policyHref = '/privacy' } = Astro.props;
---

<aside
  hidden
  class="fixed bottom-4 left-4 right-4 z-50 rounded-lg border border-ink/10 bg-paper/96 p-4 shadow-2xl backdrop-blur dark:border-white/10 dark:bg-ink/96 md:bottom-6 md:left-1/2 md:right-auto md:w-[calc(100%-3rem)] md:max-w-4xl md:-translate-x-1/2 md:p-5"
  data-cookie-banner
  role="dialog"
  aria-modal="true"
  aria-labelledby="cookie-banner-title"
  aria-describedby="cookie-banner-copy"
>
  <div class="flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
    <div class="max-w-2xl">
      <p id="cookie-banner-title" class="text-xs font-semibold uppercase tracking-[0.22em] text-teal dark:text-tealSoft">
        Cookie preferences
      </p>
      <p id="cookie-banner-copy" class="mt-2 text-sm leading-relaxed text-ink/75 dark:text-paper/80">
        We use essential cookies for site operation. If you accept analytics, Google Analytics 4 may
        set first-party cookies to help us understand traffic and improve the site.
      </p>
      <p class="mt-2 text-xs leading-relaxed text-ink/60 dark:text-paper/60">
        Your choice is stored locally in your browser. You can change it later from the footer or
        review the
        <a href={policyHref} class="underline decoration-accent/50 underline-offset-4 hover:text-teal dark:decoration-accent/50 dark:hover:text-accentMuted">
          Privacy Policy
        </a>.
      </p>
    </div>

    <div class="flex flex-col gap-3 sm:flex-row">
      <button
        type="button"
        class="inline-flex items-center justify-center rounded-full bg-accent px-5 py-3 text-sm font-semibold text-ink shadow-sm transition hover:bg-accentMuted focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-paper dark:focus-visible:ring-offset-ink"
        data-cookie-accept
      >
        Accept analytics
      </button>
      <button
        type="button"
        class="inline-flex items-center justify-center rounded-full border border-ink/15 bg-white/70 px-5 py-3 text-sm font-semibold text-ink transition hover:border-teal hover:bg-white focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-accent focus-visible:ring-offset-2 focus-visible:ring-offset-paper dark:border-white/15 dark:bg-white/5 dark:text-paper/80 dark:hover:border-accentMuted dark:hover:bg-white/10 dark:focus-visible:ring-offset-ink"
        data-cookie-reject
      >
        Essential only
      </button>
    </div>
  </div>
</aside>

<script is:inline define:vars={{ analyticsId }}>
  (() => {
    const STORAGE_KEY = 'cm-cookie-consent';
    const ACCEPTED = 'accepted';
    const REJECTED = 'rejected';

    const banner = document.querySelector('[data-cookie-banner]');
    if (!banner) return;

    const acceptButtons = document.querySelectorAll('[data-cookie-accept]');
    const rejectButtons = document.querySelectorAll('[data-cookie-reject]');

    const loadAnalytics = () => {
      if (window.__cmAnalyticsLoaded) return;

      window.dataLayer = window.dataLayer || [];
      window.gtag =
        window.gtag ||
        function gtag() {
          window.dataLayer.push(arguments);
        };

      const script = document.createElement('script');
      script.async = true;
      script.src = `https://www.googletagmanager.com/gtag/js?id=${encodeURIComponent(analyticsId)}`;
      document.head.appendChild(script);

      window.gtag('js', new Date());
      window.gtag('config', analyticsId);
      window.__cmAnalyticsLoaded = true;
    };

    const hideBanner = () => {
      banner.setAttribute('hidden', '');
    };

    const showBanner = () => {
      banner.removeAttribute('hidden');
    };

    const storeConsent = (value) => {
      try {
        window.localStorage.setItem(STORAGE_KEY, value);
      } catch (error) {}
      if (value === ACCEPTED) {
        loadAnalytics();
      }
      hideBanner();
    };

    let storedConsent = null;
    try {
      storedConsent = window.localStorage.getItem(STORAGE_KEY);
    } catch (error) {}
    if (storedConsent === ACCEPTED) {
      loadAnalytics();
      hideBanner();
    } else if (storedConsent === REJECTED) {
      hideBanner();
    } else {
      showBanner();
    }

    acceptButtons.forEach((button) => {
      button.addEventListener('click', () => storeConsent(ACCEPTED));
    });

    rejectButtons.forEach((button) => {
      button.addEventListener('click', () => storeConsent(REJECTED));
    });

    window.addEventListener('cm:open-cookie-banner', showBanner);
  })();
</script>
