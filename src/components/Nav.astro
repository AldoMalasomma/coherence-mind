---
import type { NavigationLink } from '../lib/types';

const fallback = [
  { _id: 'model', label: 'Model', href: '/model', order: 1 },
  { _id: 'glossary', label: 'Glossary', href: '/glossary', order: 2 },
  { _id: 'timeline', label: 'Timeline', href: '/timeline', order: 3 },
  { _id: 'blog', label: 'Articles', href: '/blog', order: 4 }
] satisfies NavigationLink[];

const {
  links = [] as NavigationLink[],
  layout = 'inline'
} = Astro.props;

const navItems: NavigationLink[] = links.length ? links : fallback;
const listClass =
  layout === 'inline'
    ? 'flex flex-wrap gap-5 text-xs font-semibold uppercase tracking-[0.24em] text-ink/60 dark:text-paper/65'
    : 'flex flex-col gap-2 text-base font-medium text-ink dark:text-paper';
const linkClass =
  layout === 'inline'
    ? 'transition hover:text-teal focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent dark:hover:text-accentMuted'
    : 'block rounded-lg px-3 py-2 text-ink transition hover:bg-paper focus-visible:outline focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-accent dark:text-paper dark:hover:bg-white/10';
---
<nav aria-label="Primary">
  <ul class={listClass}>
    {navItems.map((link) => (
      <li>
        <a
          class={linkClass}
          href={link.href}
        >
          {link.label}
        </a>
      </li>
    ))}
  </ul>
</nav>
