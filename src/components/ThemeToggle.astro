<button
  type="button"
  class="inline-flex h-10 items-center gap-2 rounded-full border border-ink/15 px-3 text-xs font-semibold uppercase tracking-[0.2em] text-ink/70 transition hover:border-teal hover:text-teal dark:border-white/15 dark:text-paper/70 dark:hover:border-accentMuted dark:hover:text-accentMuted"
  data-theme-toggle
  data-theme="light"
  aria-label="Change color theme"
>
  <span class="relative inline-flex h-5 w-5 items-center justify-center" aria-hidden="true">
    <span data-theme-icon="light" class="flex h-full w-full items-center justify-center">
      <span class="h-3.5 w-3.5 rounded-full bg-accent shadow-[0_0_16px_rgba(217,148,43,0.45)]"></span>
    </span>
    <span data-theme-icon="dark" class="absolute inset-0 hidden items-center justify-center text-paper">
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" class="h-3.5 w-3.5">
        <path
          stroke-linecap="round"
          stroke-linejoin="round"
          stroke-width="1.5"
          d="M21 12.79A9 9 0 1 1 11.21 3a7 7 0 0 0 9.79 9.79Z"
        />
      </svg>
    </span>
    <span data-theme-icon="accessible" class="absolute inset-0 hidden items-center justify-center text-[10px] font-semibold tracking-wide text-ink dark:text-paper">
      A+
    </span>
  </span>
  <span data-theme-label class="hidden md:inline">Light</span>
</button>
